{
  "name": "verifiabl",
  "version": "0.13.0",
  "description": "Official Verifiabl Node.js SDK for issuing payslip QR codes, formatting PII, AES-256-GCM encryption helpers, and typed issuer API calls.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Verifiabl/verifiabl-node.git"
  },
  "homepage": "https://verifiabl.io",
  "keywords": [
    "verifiabl",
    "payslip",
    "issuer",
    "qr-code",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "jest",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "bench": "npm run build && node scripts/bench-png.mjs",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/jest": "^29.5.14",
    "@types/pngjs": "^6.0.5",
    "@types/qrcode": "^1.5.5",
    "jest": "^29.7.0",
    "jsqr": "^1.4.0",
    "pngjs": "^5.0.0",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@resvg/resvg-js": "^2.6.0"
  },
  "peerDependenciesMeta": {
    "@resvg/resvg-js": {
      "optional": true
    }
  },
  "overrides": {
    "esbuild": "0.28.1",
    "js-yaml": "^4.2.0"
  }
}
